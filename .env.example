# Skal matche basePath i next.config.ts
NEXT_PUBLIC_BASE_PATH=/gf2

# Notion internal integration token (https://www.notion.so/my-integrations)
NOTION_API_KEY=

# Cache TTL for Notion pages (seconds)
NOTION_REVALIDATE_SECONDS=120

# Optional: database ID for future course overview sync
NOTION_DATABASE_ID=
