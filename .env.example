# GF2-Learn — Docker Compose
# Kopiér til .env og udfyld secrets (filen er gitignored).
# Prod og dev på samme server: to Dokploy-apps med hver sin .env (unikt TRAEFIK_PREFIX + APP_DOMAIN).

# Domæne + Traefik (påkrævet ved flere miljøer på samme server)
APP_DOMAIN=learn.gf2.dk
TRAEFIK_PREFIX=gf2learn-prod

# Videnscenter (VAT) branding — true på VC-branchen til aflevering, false internt hos Mercantec
VidenscenterBranding__Enabled=true

# Postgres (postgres-service i Docker — web forbinder internt på postgres:5432)
POSTGRES_DB=gf2learn
POSTGRES_USER=gf2
# VIGTIGT: Må ikke ændres efter første deploy uden at slette pgdata-volume
POSTGRES_PASSWORD=changeme

# Lokal Docker (docker-compose.local.yml)
WEB_HOST_PORT=8031

# ASP.NET Core — GF2_BEHIND_REVERSE_PROXY=true sættes i docker-compose.yml
ASPNETCORE_ENVIRONMENT=Production
PathBase=
ContentPath=/app/content
# Persistér login-cookies på tværs af container-genstart (docker-compose volume dataprotection)
DataProtection__KeysPath=/app/data-protection-keys

# OpenAI (opgave-hints og løsnings-tjek — kun på serveren, aldrig i browseren)
# Brug dobbelt underscore __ (ASP.NET konvention). Filen skal ligge i projektroden (GF2-Learn/.env).
OpenAi__ApiKey=
OpenAi__Model=gpt-4o-mini

# Mercantec Auth (OAuth 2.0 + PKCE)
MercantecAuth__ClientId=gf2-learn
MercantecAuth__ClientSecret=
MercantecAuth__Issuer=https://auth.mercantec.tech
MercantecAuth__Audience=mercantec-apps
MercantecAuth__AuthorizationEndpoint=https://auth.mercantec.tech/oauth/authorize
MercantecAuth__TokenEndpoint=https://auth.mercantec.tech/oauth/token
MercantecAuth__SignOutEndpoint=https://auth.mercantec.tech/signout
MercantecAuth__CallbackPath=/signin-mercantec
MercantecAuth__CookieName=.gf2learn.auth

# --- Dev (.env på VC-branchen i anden Dokploy-app) ---
# APP_DOMAIN=vc.gf2.dk
# TRAEFIK_PREFIX=gf2learn-dev
# VidenscenterBranding__Enabled=true
# POSTGRES_PASSWORD=<andet end prod>
# OAuth redirect i Auth Admin: https://vc.mercantec.tech/signin-mercantec

