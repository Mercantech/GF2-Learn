# GF2-Learn — Docker Compose
# Kopiér til .env og udfyld secrets (filen er gitignored).

# Postgres (postgres-service)
POSTGRES_DB=gf2learn
POSTGRES_USER=gf2
POSTGRES_PASSWORD=changeme
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ASP.NET Core (i container lytter appen på 8080; docker-compose mapper host 2020→8080)
# Cloudflare Tunnel (dashboard): learn-dev.gf2.dk → http://localhost:2020 — se deploy/cloudflare-tunnel.md
ASPNETCORE_ENVIRONMENT=Production
PathBase=
ContentPath=/app/content

# Mercantec Auth (OAuth 2.0 + PKCE)
MercantecAuth__ClientId=gf2-learn
MercantecAuth__ClientSecret=
MercantecAuth__Issuer=https://auth.mercantec.tech
MercantecAuth__Audience=mercantec-apps
MercantecAuth__AuthorizationEndpoint=https://auth.mercantec.tech/oauth/authorize
MercantecAuth__TokenEndpoint=https://auth.mercantec.tech/oauth/token
MercantecAuth__SignOutEndpoint=https://auth.mercantec.tech/signout
MercantecAuth__CallbackPath=/signin-mercantec
MercantecAuth__CookieName=.gf2learn.auth
