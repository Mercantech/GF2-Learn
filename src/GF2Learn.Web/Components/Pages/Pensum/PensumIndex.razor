@page "/curriculum"
@inject ContentService Content

<PageTitle>Curriculum — GF2 Learn</PageTitle>

<SectionShell Section="ContentSectionType.Curriculum" Title="Curriculum">
    <SectionHero Title="Curriculum" Eyebrow="Theory" Lead="C#-grundlag og Git — læs emnerne i rækkefølge, eller hop direkte til det du har brug for.">
        <span class="hero-chip">@CurriculumCount emner</span>
    </SectionHero>
    <div class="index-list">
        @foreach (var item in Content.GetAll().Where(i => i.Section == ContentSectionType.Curriculum).OrderBy(i => i.Order))
        {
            <a href="@item.Href" class="index-item">
                <span class="index-order">@item.Order.ToString("D2")</span>
                <div class="index-item-body">
                    <strong>@item.Title</strong>
                    @if (item.Timer > 0) { <span class="index-meta">@item.Timer timer</span> }
                </div>
                <span class="index-arrow">→</span>
            </a>
        }
    </div>
</SectionShell>

@code {
    private int CurriculumCount => Content.GetAll().Count(i => i.Section == ContentSectionType.Curriculum);
}
