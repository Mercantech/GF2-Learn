@page "/curriculum"
@using System.Security.Claims
@using GF2Learn.Web.Models
@using GF2Learn.Web.Services
@inject ContentService Content
@inject KnowledgeCheckCatalog Catalog
@inject IHttpContextAccessor HttpContextAccessor
@inject KnowledgeCheckProgressScope ProgressScope

<PageTitle>Curriculum — GF2 Learn</PageTitle>

    <SectionShell Section="ContentSectionType.Curriculum" Title="Curriculum">
    <div class="curriculum-index">
    <SectionHero Title="Curriculum" Eyebrow="Theory" Lead="C#-grundlag, kode-principper og Git — læs emnerne i rækkefølge, eller hop direkte til det du har brug for.">
        <span class="hero-chip">@CurriculumCount emner</span>
    </SectionHero>
    @foreach (var category in CurriculumCategoryCatalog.All)
    {
        var groupItems = Content.GetAll()
            .Where(i => i.Section == ContentSectionType.Curriculum)
            .Where(i => string.Equals(
                CurriculumCategoryCatalog.ResolveCategory(i),
                category.Key,
                StringComparison.OrdinalIgnoreCase))
            .OrderBy(i => i.Order)
            .ToList();

        if (groupItems.Count == 0)
        {
            continue;
        }

        <section class="index-section index-section-category">
            <h2><span class="level-icon">@category.Icon</span> @category.Title</h2>
            <div class="index-list">
                @foreach (var item in groupItems)
                {
                    <a href="@item.Href" class="index-item" data-curriculum-slug="@item.Slug" data-enhance-nav="false">
                        <span class="index-order">@item.Order.ToString("D2")</span>
                        <div class="index-item-body">
                            <strong>@item.Title</strong>
                            @if (item.Timer > 0) { <span class="index-meta">@item.Timer timer</span> }
                        </div>
                        @if (_completedSlugs.Contains(item.Slug))
                        {
                            <span class="index-check" aria-label="Fuldført" title="Alle spørgsmål besvaret">✓</span>
                        }
                        else
                        {
                            <span class="index-arrow">→</span>
                        }
                    </a>
                }
            </div>
        </section>
    }
    </div>
</SectionShell>

@code {
    private HashSet<string> _completedSlugs = [];

    private int CurriculumCount => Content.GetAll().Count(i => i.Section == ContentSectionType.Curriculum);

    protected override async Task OnInitializedAsync()
    {
        var http = HttpContextAccessor.HttpContext;
        if (http?.User.Identity?.IsAuthenticated != true)
            return;

        var userSub = http.User.FindFirstValue(ClaimTypes.NameIdentifier)
            ?? http.User.FindFirstValue("sub");
        if (userSub is null)
            return;

        var chapters = Content.GetAll()
            .Where(i => i.Section == ContentSectionType.Curriculum)
            .Select(i => (i.Slug, Catalog.CountQuestions(i.Body)))
            .ToList();

        var progress = await ProgressScope.TryExecuteAsync(
            (svc, ct) => svc.GetCurriculumProgressAsync(userSub, chapters, ct),
            fallback: (IReadOnlyList<CurriculumChapterProgress>)[]);

        _completedSlugs = progress
            .Where(p => p.IsComplete)
            .Select(p => p.ContentSlug)
            .ToHashSet(StringComparer.Ordinal);
    }
}
