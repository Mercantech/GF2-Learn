@page "/profile"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@using System.Security.Claims

<PageTitle>Profile — GF2 Learn</PageTitle>

<div class="profile-page">
    <SectionHero Title="Profile" Eyebrow="Account" Lead="Du er logget ind via Mercantec Auth." />

    <div class="profile-card">
        <div class="profile-avatar-large">@GetInitials(User)</div>
        <dl class="profile-list">
            <div class="profile-row">
                <dt>Navn</dt>
                <dd>@(User.FindFirst(ClaimTypes.Name)?.Value ?? "—")</dd>
            </div>
            <div class="profile-row">
                <dt>E-mail</dt>
                <dd>@(User.FindFirst(ClaimTypes.Email)?.Value ?? "—")</dd>
            </div>
            <div class="profile-row">
                <dt>Bruger-ID</dt>
                <dd><code>@(User.FindFirst("sub")?.Value ?? "—")</code></dd>
            </div>
            <div class="profile-row">
                <dt>Login-metode</dt>
                <dd>@(User.FindFirst("login_method")?.Value ?? "—")</dd>
            </div>
            @if (User.FindAll(ClaimTypes.Role).Any())
            {
                <div class="profile-row">
                    <dt>Roller</dt>
                    <dd>
                        @foreach (var role in User.FindAll(ClaimTypes.Role))
                        {
                            <span class="meta-chip">@role.Value</span>
                        }
                    </dd>
                </div>
            }
        </dl>
        <div class="profile-actions">
            <a href="/curriculum" class="btn btn-secondary">Fortsæt med pensum</a>
            <a href="/auth/logout" class="btn btn-ghost">Log ud</a>
        </div>
    </div>

    <section class="profile-card theme-settings" aria-labelledby="theme-settings-title">
        <div class="theme-settings-heading">
            <div>
                <span class="theme-settings-eyebrow">Indstillinger</span>
                <h2 id="theme-settings-title">Design</h2>
            </div>
            <p>Vælg det tema, der skal bruges på denne enhed.</p>
        </div>

        <div class="theme-options" role="group" aria-label="Vælg design">
            <button type="button" class="theme-option" data-theme-option="light" aria-pressed="false">
                <span class="theme-option-preview theme-option-preview-light" aria-hidden="true">
                    <span>GF2&gt;_</span>
                </span>
                <span class="theme-option-copy">
                    <strong>Lys</strong>
                    <small>Klar og rolig</small>
                </span>
                <span class="theme-option-check" aria-hidden="true">Valgt</span>
            </button>

            <button type="button" class="theme-option" data-theme-option="dark" aria-pressed="false">
                <span class="theme-option-preview theme-option-preview-dark" aria-hidden="true">
                    <span>GF2&gt;_</span>
                </span>
                <span class="theme-option-copy">
                    <strong>Mørk</strong>
                    <small>Dæmpet og moderne</small>
                </span>
                <span class="theme-option-check" aria-hidden="true">Valgt</span>
            </button>

            <button type="button" class="theme-option" data-theme-option="dos" aria-pressed="false">
                <span class="theme-option-preview theme-option-preview-dos" aria-hidden="true">
                    <span>C:\GF2&gt;_</span>
                </span>
                <span class="theme-option-copy">
                    <strong>DOS</strong>
                    <small>Klassisk terminalgrøn</small>
                </span>
                <span class="theme-option-check" aria-hidden="true">Valgt</span>
            </button>
        </div>

        <p class="theme-settings-status" data-theme-status aria-live="polite"></p>
    </section>
</div>

@code {
    [CascadingParameter] private Task<AuthenticationState>? AuthStateTask { get; set; }
    private ClaimsPrincipal User { get; set; } = new(new ClaimsIdentity());

    protected override async Task OnInitializedAsync()
    {
        if (AuthStateTask is not null)
            User = (await AuthStateTask).User;
    }

    private string GetInitials(ClaimsPrincipal user)
    {
        var name = user.Identity?.Name ?? user.FindFirst(ClaimTypes.Email)?.Value ?? "?";
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length >= 2) return $"{parts[0][0]}{parts[^1][0]}".ToUpperInvariant();
        return name.Length > 0 ? char.ToUpperInvariant(name[0]).ToString() : "?";
    }
}
