@page "/projects"
@inject ContentService Content

<PageTitle>Projects — GF2 Learn</PageTitle>

<SectionShell Section="ContentSectionType.Projects" Title="Projects">
    <SectionHero Title="Projects" Eyebrow="Courses" Lead="Projektforløb fra begynder til enterprise. Hvert projekt har en side med aflevering og reference-løsninger." />

    @{
        var levels = new[] { ("begynder", "Begynder"), ("mellem", "Mellem"), ("avanceret", "Avanceret") };
        var projects = Content.GetAll().Where(i => i.Section == ContentSectionType.Projects && i.IsOverview).ToList();
    }

    @foreach (var (key, label) in levels)
    {
        var group = projects
            .Where(p => string.Equals(p.Difficulty, key, StringComparison.OrdinalIgnoreCase))
            .OrderBy(p => p.Order)
            .ToList();
        if (group.Count == 0) { continue; }

        <section class="project-level">
            <h2 class="project-level-title">@label</h2>
            <div class="project-grid">
                @foreach (var project in group)
                {
                    <a href="@project.Href" class="project-card">
                        <h3>@project.Title</h3>
                        <p>Projektbeskrivelse · Git-aflevering</p>
                        <span class="project-arrow">Se forløb →</span>
                    </a>
                }
            </div>
        </section>
    }
</SectionShell>
