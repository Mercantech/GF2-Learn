@page "/projects/{ProjectSlug}"
@inject ContentService Content

<PageTitle>@(Overview?.Title ?? "Project") — GF2 Learn</PageTitle>

@if (Overview is null)
{
    <p>Projektet blev ikke fundet.</p>
}
else
{
    <SectionShell Section="ContentSectionType.Projects" Title="Projects" Current="Overview">
        <header class="page-header">
            <p class="breadcrumb"><a href="/projects">Projects</a> / @Overview.Title</p>
            <h1>@Overview.Title</h1>
            <ContentMeta Item="Overview" />
        </header>
        <MarkdownContent Item="Overview" />
        <section class="day-list">
            <h2>Days</h2>
            <div class="index-list">
                @foreach (var day in Content.GetAll().Where(i => i.ProjectSlug == ProjectSlug && !i.IsOverview).OrderBy(i => i.Order))
                {
                    <a href="@day.Href" class="index-item">
                        <span class="index-order">@day.Order.ToString("D2")</span>
                        <strong>@day.Title</strong>
                    </a>
                }
            </div>
        </section>
    </SectionShell>
}

@code {
    [Parameter] public string ProjectSlug { get; set; } = "";
    private ContentItem? Overview => Content.GetProjectOverview(ProjectSlug);
}
