@page "/projects/{ProjectSlug}/{DaySlug}"
@inject ContentService Content

<PageTitle>@(Item?.Title ?? "Project day") — GF2 Learn</PageTitle>

@if (Item is null)
{
    <p>Projektdagen blev ikke fundet.</p>
}
else
{
    <SectionShell Section="ContentSectionType.Projects" Title="Projects" Current="Item">
        <header class="page-header">
            <p class="breadcrumb">
                <a href="/projects">Projects</a> /
                <a href="/projects/@ProjectSlug">@ProjectSlug</a> /
                @Item.Title
            </p>
            <h1>@Item.Title</h1>
            <ContentMeta Item="Item" />
        </header>
        <MarkdownContent Item="Item" />
    </SectionShell>
}

@code {
    [Parameter] public string ProjectSlug { get; set; } = "";
    [Parameter] public string DaySlug { get; set; } = "";
    private ContentItem? Item => Content.GetProjectDay(ProjectSlug, DaySlug);
}
