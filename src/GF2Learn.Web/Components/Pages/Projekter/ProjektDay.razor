@page "/projects/{ProjectSlug}/{DaySlug}"
@inject ContentService Content
@inject NavigationManager Navigation

@code {
    [Parameter] public string ProjectSlug { get; set; } = "";
    [Parameter] public string DaySlug { get; set; } = "";

    protected override void OnInitialized()
    {
        var overview = Content.GetProjectOverview(ProjectSlug);
        if (overview is not null)
            Navigation.NavigateTo(overview.Href, replace: true);
    }
}
