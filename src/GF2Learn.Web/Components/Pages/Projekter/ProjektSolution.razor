@page "/projects/{ProjectSlug}/solution"
@inject ContentService Content
@inject ProjectSolutionCatalog SolutionCatalog

<PageTitle>@(Overview?.Title ?? "Projekt") — løsning & aflevering — GF2 Learn</PageTitle>

@if (Overview is null || Solution is null)
{
    <p>Projektet blev ikke fundet.</p>
}
else
{
    <SectionShell Section="ContentSectionType.Projects" Title="Projects" Current="Overview">
        <header class="page-header">
            <p class="breadcrumb">
                <a href="/projects">Projects</a> /
                <a href="@Overview.Href">@Overview.Title</a> /
                Løsning & aflevering
            </p>
            <h1>@Overview.Title — reference</h1>
            <p class="page-lead">Det I skal aflevere, og hvordan en løsning kan se ud (konsol + Blazor).</p>
        </header>

        <div class="callout callout-info project-solution-disclaimer">
            <p><strong>Undervisningsreference.</strong> Konsol-delen viser kun programmets adfærd (som en .exe), ikke kildekoden. Blazor-demos viser UI-idéer — lav jeres egen løsning til aflevering.</p>
        </div>

        <ProjectDeliverablesPanel Expectations="Solution.Deliverables" />

        @if (HasInteractiveContent)
        {
            <ProjectSolutionInteractiveHost
                Slug="@ProjectSlug"
                ConsoleCode="@Solution.ConsoleDemoCode"
                ShowMvp="@(Solution.MvpBlazorComponent is not null)"
                ShowExtended="@(Solution.ExtendedBlazorComponent is not null)" />
        }

        <p class="project-solution-back">
            <a href="@Overview.Href" class="btn btn-ghost btn-sm">← Tilbage til projektbeskrivelse</a>
        </p>
    </SectionShell>
}

@code {
    [Parameter] public string ProjectSlug { get; set; } = "";
    private ContentItem? Overview => Content.GetProjectOverview(ProjectSlug);
    private ProjectSolutionInfo? Solution => SolutionCatalog.Get(ProjectSlug);
    private bool HasInteractiveContent =>
        Solution is not null && (
            !string.IsNullOrWhiteSpace(Solution.ConsoleDemoCode) ||
            Solution.MvpBlazorComponent is not null ||
            Solution.ExtendedBlazorComponent is not null);
}
