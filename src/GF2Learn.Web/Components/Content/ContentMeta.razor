@using GF2Learn.Web.Models
@using GF2Learn.Web.Services

@if (Item.Timer > 0 || !string.IsNullOrWhiteSpace(Item.Difficulty) || !string.IsNullOrWhiteSpace(CategoryTitle) || Item.Topics.Count > 0)
{
    <aside class="content-meta">
        @if (Item.Timer > 0)
        {
            <span class="meta-chip">@Item.Timer timer</span>
        }
        @if (!string.IsNullOrWhiteSpace(CategoryTitle))
        {
            <span class="meta-chip meta-chip-category">@CategoryTitle</span>
        }
        else if (!string.IsNullOrWhiteSpace(Item.Difficulty))
        {
            <span class="meta-chip meta-chip-level">@Item.Difficulty</span>
        }
        @foreach (var topic in Item.Topics)
        {
            <span class="meta-chip">@topic</span>
        }
    </aside>
}

@code {
    [Parameter, EditorRequired] public ContentItem Item { get; set; } = default!;

    private string? CategoryTitle => Item.Section switch
    {
        ContentSectionType.Curriculum => CurriculumCategoryCatalog.GetTitle(Item.Category),
        ContentSectionType.Exercises => ExerciseCategoryCatalog.GetTitle(Item.Category),
        _ => null
    };
}
