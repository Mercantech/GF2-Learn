@using System.Security.Claims
@using GF2Learn.Web.Models
@using GF2Learn.Web.Services

@if (Nav is null)
{
    return;
}

<aside class="sidebar">
    <p class="sidebar-title">@Title</p>
    @foreach (var group in Nav.Groups)
    {
        <div class="sidebar-group">
            @if (!string.IsNullOrWhiteSpace(group.Title))
            {
                <p class="sidebar-group-title">@group.Title</p>
            }
            <ul>
                @foreach (var item in group.Items)
                {
                    var active = IsActive(item);
                    <li>
                        <a href="@item.Href"
                           class="sidebar-link @(active ? "active" : null)"
                           data-enhance-nav="@(Nav.Section is ContentSectionType.Exercises or ContentSectionType.Curriculum ? "false" : null)"
                           data-curriculum-slug="@(Nav.Section == ContentSectionType.Curriculum ? item.Slug : null)"
                           data-exercise-slug="@(Nav.Section == ContentSectionType.Exercises ? item.Slug : null)">
                            <span class="sidebar-link-text">@item.Title</span>
                            @if (IsItemComplete(item))
                            {
                                <span class="sidebar-check" aria-label="Fuldført" title="@CompleteTitle(item)">✓</span>
                            }
                        </a>
                    </li>
                }
            </ul>
        </div>
    }
</aside>

@code {
    [Parameter] public SectionNav? Nav { get; set; }
    [Parameter] public string Title { get; set; } = "Navigation";
    [Parameter] public ContentItem? Current { get; set; }

    [Inject] private IHttpContextAccessor HttpContextAccessor { get; set; } = default!;
    [Inject] private ContentService Content { get; set; } = default!;
    [Inject] private KnowledgeCheckCatalog Catalog { get; set; } = default!;
    [Inject] private ExerciseCatalog ExerciseCatalog { get; set; } = default!;
    [Inject] private KnowledgeCheckProgressScope ProgressScope { get; set; } = default!;
    [Inject] private ExerciseProgressScope ExerciseProgressScope { get; set; } = default!;

    private HashSet<string> _completedSlugs = [];

    protected override async Task OnInitializedAsync()
    {
        if (Nav is null)
            return;

        var http = HttpContextAccessor.HttpContext;
        if (http?.User.Identity?.IsAuthenticated != true)
            return;

        var userSub = http.User.FindFirstValue(ClaimTypes.NameIdentifier)
            ?? http.User.FindFirstValue("sub");
        if (userSub is null)
            return;

        if (Nav.Section == ContentSectionType.Curriculum)
        {
            var chapters = Content.GetAll()
                .Where(i => i.Section == ContentSectionType.Curriculum)
                .Select(i => (i.Slug, Catalog.CountQuestions(i.Body)))
                .ToList();

            var progress = await ProgressScope.TryExecuteAsync(
                (svc, ct) => svc.GetCurriculumProgressAsync(userSub, chapters, ct),
                fallback: (IReadOnlyList<CurriculumChapterProgress>)[]);

            _completedSlugs = progress
                .Where(p => p.IsComplete)
                .Select(p => p.ContentSlug)
                .ToHashSet(StringComparer.Ordinal);
            return;
        }

        if (Nav.Section == ContentSectionType.Exercises)
        {
            var exercises = Content.GetAll()
                .Where(i => i.Section == ContentSectionType.Exercises)
                .Select(i => (i.Slug, ExerciseCatalog.CountParts(i.Body)))
                .ToList();

            var progress = await ExerciseProgressScope.TryExecuteAsync(
                (svc, ct) => svc.GetExerciseProgressAsync(userSub, exercises, ct),
                fallback: (IReadOnlyList<ExerciseChapterProgress>)[]);

            _completedSlugs = progress
                .Where(p => p.IsComplete)
                .Select(p => p.ContentSlug)
                .ToHashSet(StringComparer.Ordinal);
        }
    }

    private bool IsActive(ContentItem item) =>
        Current != null && Current.Slug == item.Slug && Current.Section == item.Section
        && Current.ProjectSlug == item.ProjectSlug;

    private bool IsItemComplete(ContentItem item) =>
        Nav is not null && _completedSlugs.Contains(item.Slug);

    private static string CompleteTitle(ContentItem item) =>
        item.Section == ContentSectionType.Exercises
            ? "Alle opgavedele løst"
            : "Alle spørgsmål besvaret";
}
