@using GF2Learn.Web.Auth
@using GF2Learn.Web.Options
@using Microsoft.Extensions.Options
@inject NavigationManager Navigation
@inject IOptions<VidenscenterBrandingOptions> VidenscenterBranding

<footer class="site-footer">
    @if (VidenscenterBranding.Value.Enabled)
    {
        <div class="site-footer-vat-bar">
            <div class="site-footer-vat-bar-inner">
                <p class="site-footer-vat-label">Udviklet med støtte fra</p>
                <VidenscenterLogo Size="footer" ShowPortal="true" />
            </div>
        </div>
    }

    <div class="site-footer-inner">
        <div class="site-footer-brand">
            <a href="/" class="site-footer-gf2">
                <span class="site-logo-text">GF2<span class="site-logo-accent">Learn</span></span>
            </a>
            <p>Læringsplatform til Grundforløb 2 programmering på Mercantec.</p>
        </div>
        <div class="site-footer-links">
            <div>
                <p class="site-footer-label">Learn</p>
                <a href="/curriculum">Curriculum</a>
                <a href="/exercises">Exercises</a>
                <a href="/projects">Projects</a>
            </div>
            <div>
                <p class="site-footer-label">Mercantec</p>
                <a href="https://mercantec.dk" target="_blank" rel="noopener">mercantec.dk</a>
                <a href="@MercantecAuthExtensions.LoginUrl(Navigation.Uri)">Log ind</a>
            </div>
        </div>
    </div>
    <p class="site-footer-copy">GF2 Data &amp; Kommunikation · C# og Git</p>
</footer>
