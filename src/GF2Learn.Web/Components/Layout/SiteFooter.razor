@using GF2Learn.Web.Auth
@inject NavigationManager Navigation

<footer class="site-footer">
    <div class="site-footer-inner">
        <div class="site-footer-brand">
            <span class="site-logo-text">GF2<span class="site-logo-accent">Learn</span></span>
            <p>Læringsplatform til Grundforløb 2 programmering på Mercantec.</p>
        </div>
        <div class="site-footer-links">
            <div>
                <p class="site-footer-label">Learn</p>
                <a href="/curriculum">Curriculum</a>
                <a href="/exercises">Exercises</a>
                <a href="/projects">Projects</a>
            </div>
            <div>
                <p class="site-footer-label">Mercantec</p>
                <a href="https://mercantec.dk" target="_blank" rel="noopener">mercantec.dk</a>
                <a href="@MercantecAuthExtensions.LoginUrl(Navigation.Uri)">Log ind</a>
            </div>
        </div>
    </div>

    <div class="site-footer-partners">
        <div class="site-footer-partner">
            <a href="https://videnscenterportalen.dk/vat/" target="_blank" rel="noopener" title="Videnscenter for Automation og Teknologi">
                <img src="images/partners/logo-vat-color.svg" alt="Videnscenter for Automation og Teknologi" class="site-footer-logo site-footer-logo--light" width="220" height="44" />
                <img src="images/partners/logo-vat-white.svg" alt="Videnscenter for Automation og Teknologi" class="site-footer-logo site-footer-logo--dark" width="220" height="44" />
            </a>
            <p>Et udviklingsprojekt støttet af Videnscenter for Automation og Teknologi</p>
        </div>
        <div class="site-footer-partner">
            <a href="https://videnscenterportalen.dk/" target="_blank" rel="noopener" title="Videnscenterportalen">
                <img src="images/partners/logo-videnscenterportalen-dark.svg" alt="Videnscenterportalen" class="site-footer-logo site-footer-logo--light" width="180" height="36" />
                <img src="images/partners/logo-videnscenterportalen.svg" alt="Videnscenterportalen" class="site-footer-logo site-footer-logo--dark" width="180" height="36" />
            </a>
            <p>En del af Videnscenterportalen</p>
        </div>
    </div>

    <p class="site-footer-copy">GF2 Data &amp; Kommunikation · C# og Git</p>
</footer>
