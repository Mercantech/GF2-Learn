<button type="button" class="theme-toggle" data-theme-toggle title="Skift mellem lys og mørk" aria-label="Skift tema" role="switch">
    <span class="theme-toggle-track">
        <span class="theme-toggle-icon theme-toggle-sun" aria-hidden="true">
            <svg viewBox="0 0 24 24" width="16" height="16">
                <circle cx="12" cy="12" r="4" fill="none" stroke="currentColor" stroke-width="1.75"/>
                <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/>
            </svg>
        </span>
        <span class="theme-toggle-icon theme-toggle-moon" aria-hidden="true">
            <svg viewBox="0 0 24 24" width="16" height="16">
                <path d="M21 14.5A8.5 8.5 0 0 1 9.5 3 7 7 0 1 0 21 14.5z" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linejoin="round"/>
            </svg>
        </span>
        <span class="theme-toggle-thumb" aria-hidden="true"></span>
    </span>
</button>
