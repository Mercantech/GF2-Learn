    <script src="@Assets["js/exercise-page-load.js"]"></script>
    <script src="@Assets["_framework/blazor.web.js"]"></script>
    <script src="@Assets["js/highlight-nav.js"]"></script>
    <script src="@Assets["js/knowledge-check.js"]"></script>
    <script src="@Assets["js/gf2-api.js"]"></script>
    <script src="@Assets["js/exercise-progress.js"]"></script>
    <script src="@Assets["js/exercise-ai.js"]"></script>
