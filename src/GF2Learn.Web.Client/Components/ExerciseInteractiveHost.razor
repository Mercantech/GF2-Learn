@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))
@using System.Net.Http.Json
@using GF2Learn.Web.Client.Models
@using GF2Learn.Web.Client.Services

@foreach (var segment in _segments)
{
    @if (segment is ExercisePartSegment part)
    {
        <section class="exercise-part exercise-part-ide" data-part-index="@part.PartIndex" data-content-slug="@ContentSlug">
            @((MarkupString)part.CardHtml)
            <ExercisePartEditor @key="@($"{ContentSlug}-{part.PartIndex}")"
                                ContentSlug="@ContentSlug"
                                PartIndex="@part.PartIndex"
                                InitialCode="@part.Code"
                                SavedCode="@GetSavedCode(part.PartIndex)"
                                IsVerified="@IsPartVerified(part.PartIndex)"
                                OnSaved="HandleSavedAsync"
                                OnVerified="() => HandleVerifiedAsync(part.PartIndex)" />
        </section>
    }
    else if (segment is HtmlSegment html)
    {
        @((MarkupString)html.Html)
    }
}

@code {
    [Parameter, EditorRequired] public string ContentSlug { get; set; } = "";
    [Parameter] public IReadOnlyList<ExerciseBlockTransfer> Blocks { get; set; } = [];
    [Parameter] public IReadOnlyList<ExercisePartAnswerDto> SavedParts { get; set; } = [];
    [Parameter] public IReadOnlyList<ExercisePartVerificationDto> VerifiedParts { get; set; } = [];
    [Parameter] public EventCallback OnProgressChanged { get; set; }

    [Inject] private IJSRuntime Js { get; set; } = default!;
    [Inject] private IHttpClientFactory HttpClientFactory { get; set; } = default!;

    private IReadOnlyList<ExercisePageSegment> _segments = [];
    private List<ExercisePartAnswerDto> _resolvedParts = [];

    protected override void OnParametersSet()
    {
        _segments = ExerciseSegmentBuilder.Build(Blocks);
        if (SavedParts.Count > 0)
            _resolvedParts = SavedParts.ToList();
    }

    protected override async Task OnInitializedAsync()
    {
        if (_resolvedParts.Count > 0)
            return;

        await ReloadLocalPartsAsync();
        if (_resolvedParts.Count > 0)
            StateHasChanged();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        try
        {
            await Js.InvokeVoidAsync("gf2ExercisePage.startWatching");
        }
        catch
        {
            /* script may not be loaded */
        }
    }

    private string? GetSavedCode(int partIndex) =>
        _resolvedParts.FirstOrDefault(p => p.PartIndex == partIndex)?.AnswerText;

    private bool IsPartVerified(int partIndex) =>
        VerifiedParts.Any(v => v.PartIndex == partIndex && v.IsSolved);

    private async Task HandleSavedAsync()
    {
        await ReloadLocalPartsAsync();
        await OnProgressChanged.InvokeAsync();
    }

    private async Task HandleVerifiedAsync(int partIndex)
    {
        try
        {
            await Js.InvokeVoidAsync("gf2ExerciseProgress.markPartComplete", ContentSlug, partIndex);
        }
        catch
        {
            // Editor shows verified state locally
        }

        await OnProgressChanged.InvokeAsync();
    }

    private async Task ReloadLocalPartsAsync()
    {
        try
        {
            var client = HttpClientFactory.CreateClient("GF2LearnApi");
            var response = await client.GetAsync(
                $"/api/progress/exercise/{Uri.EscapeDataString(ContentSlug)}");

            if (!response.IsSuccessStatusCode)
                return;

            var loaded = await response.Content.ReadFromJsonAsync<List<ExercisePartAnswerDto>>();
            if (loaded is not null)
                _resolvedParts = loaded;
        }
        catch
        {
            // Server-rendered SavedParts may still apply on full page load
        }
    }
}
