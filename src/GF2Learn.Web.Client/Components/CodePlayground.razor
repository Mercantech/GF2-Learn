@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))

<CodePlaygroundCore InitialCode="@InitialCode"
                    ExpectedOutput="@ExpectedOutput"
                    Refs="@Refs" />

@code {
    [Parameter, EditorRequired] public string InitialCode { get; set; } = "";
    [Parameter] public string ExpectedOutput { get; set; } = "";
    [Parameter] public IReadOnlyList<string> Refs { get; set; } = Array.Empty<string>();
}
