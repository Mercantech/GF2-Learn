@using System.Globalization
@using System.Net
@using System.Net.Http.Json
@using System.Text.Json
@using System.Text.Json.Serialization
@using GF2Learn.Web.Client.Models
@inject IHttpClientFactory HttpClientFactory
@inject IJSRuntime Js
@inject NavigationManager Navigation

<CodePlaygroundCore @ref="_editor"
                    @key="@($"{ContentSlug}-{PartIndex}")"
                    InitialCode="@InitialCode"
                    SavedCode="@SavedCode"
                    WrapExerciseMethod="false"
                    Title="Skriv din løsning her"
                    RunLabel="Kør"
                    ResetLabel="Nulstil"
                    EmptyOutputHint="Skriv koden efter // TODO-linjen og tryk Kør."
                    RootClass="exercise-ide-playground"
                    EditorHostClass="playground-editor-host-exercise"
                    ShowCopyButton="false"
                    EnableCtrlSave="true"
                    OnCtrlSave="SaveAsync">
    <Footer>
        <div class="exercise-ide-footer">
            @if (_versions.Count > 0)
            {
                <div class="exercise-ide-versions">
                    <label class="exercise-ide-versions-label" for="@_versionSelectId">Gemte versioner</label>
                    <select id="@_versionSelectId"
                            class="exercise-ide-version-select"
                            disabled="@(_versionLoading || !_editorReady || _versions.Count < 2)"
                            @bind="_selectedVersionKey"
                            @bind:after="OnVersionSelectedAfterBindAsync">
                        @for (var i = 0; i < _versions.Count; i++)
                        {
                            var version = _versions[i];
                            <option value="@version.Id.ToString(CultureInfo.InvariantCulture)">
                                @FormatVersionLabel(i, version.SavedAt)
                            </option>
                        }
                    </select>
                </div>
            }
            <div class="exercise-ide-actions">
                <button type="button"
                        class="btn btn-ghost btn-sm exercise-ai-btn"
                        disabled="@(!_aiEnabled || _aiBusy)"
                        title="@_aiStatusHint"
                        @onclick="GetHintAsync">
                    @(_aiHintLoading ? "Henter tip…" : "AI hjælp mig")
                </button>
                <button type="button"
                        class="btn btn-ghost btn-sm exercise-ai-btn"
                        disabled="@(!_aiEnabled || _aiBusy)"
                        title="@_aiStatusHint"
                        @onclick="CheckSolutionAsync">
                    @(_aiCheckLoading ? "Tjekker…" : "Er opgaven løst?")
                </button>
                <button type="button"
                        class="btn btn-ghost btn-sm"
                        disabled="@(!_editorReady || _formatting)"
                        title="Formater kode (Ctrl+Shift+F eller Shift+Alt+F)"
                        @onclick="FormatCodeAsync">
                    @(_formatting ? "Formaterer…" : "Formater")
                </button>
                <button type="button"
                        class="btn btn-primary btn-sm"
                        disabled="@(_saving || !_editorReady)"
                        title="Gem løsning (Ctrl+S)"
                        @onclick="SaveAsync">
                    @(_saving ? "Gemmer…" : !_editorReady ? "Indlæser editor…" : _saved ? "Gemt ✓" : "Gem løsning")
                </button>
            </div>
            @if (!string.IsNullOrWhiteSpace(_formatError))
            {
                <span class="exercise-ide-save-error">@_formatError</span>
            }
            @if (!string.IsNullOrWhiteSpace(_saveError))
            {
                <span class="exercise-ide-save-error">@_saveError</span>
            }
            @if (!string.IsNullOrWhiteSpace(_aiError))
            {
                <span class="exercise-ide-save-error">@_aiError</span>
            }
            @if (_aiRequiresLogin)
            {
                <span class="exercise-ide-save-error">
                    Log ind for at bruge AI-hjælpen.
                    <a href="@LoginUrl">Log ind</a>
                </span>
            }
        </div>
        @if (!string.IsNullOrWhiteSpace(_aiHint))
        {
            <div class="exercise-ai-panel exercise-ai-panel-hint" role="status">
                <p class="exercise-ai-panel-label">AI-tip</p>
                <p class="exercise-ai-panel-body">@_aiHint</p>
            </div>
        }
        @if (_aiCheck is not null)
        {
            <div class="exercise-ai-panel @(_aiCheck.IsSolved ? "exercise-ai-panel-ok" : "exercise-ai-panel-warn")" role="status">
                <p class="exercise-ai-panel-label">@(_aiCheck.IsSolved ? "Opgaven ser løst ud" : "Ikke helt i mål endnu")</p>
                <p class="exercise-ai-panel-body">@_aiCheck.Feedback</p>
            </div>
        }
    </Footer>
</CodePlaygroundCore>

@code {
    [Parameter, EditorRequired] public string ContentSlug { get; set; } = "";
    [Parameter] public int PartIndex { get; set; }
    [Parameter, EditorRequired] public string InitialCode { get; set; } = "";
    [Parameter] public string? SavedCode { get; set; }
    [Parameter] public EventCallback OnSaved { get; set; }

    private CodePlaygroundCore? _editor;
    private readonly string _versionSelectId = $"ver-{Guid.NewGuid():N}";
    private bool _saved;
    private bool _saving;
    private bool _formatting;
    private bool _versionLoading;
    private string? _saveError;
    private string? _formatError;
    private List<ExercisePartVersionDto> _versions = [];
    private string _selectedVersionKey = "";
    private bool _editorReady;

    private bool _aiEnabled;
    private bool _aiBusy;
    private bool _aiHintLoading;
    private bool _aiCheckLoading;
    private bool _aiRequiresLogin;
    private string? _aiStatusHint;
    private string? _aiError;
    private string? _aiHint;
    private ExerciseAiCheckResult? _aiCheck;

    private static readonly JsonSerializerOptions JsonOpts = new()
    {
        PropertyNameCaseInsensitive = true
    };

    protected override void OnParametersSet() =>
        _saved = !string.IsNullOrWhiteSpace(SavedCode) || _versions.Count > 0;

    protected override async Task OnInitializedAsync()
    {
        await Task.WhenAll(RefreshAiStatusAsync(), LoadVersionsAsync());
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_editor is null)
            return;

        var ready = await _editor.WaitForEditorReadyAsync();
        if (ready == _editorReady)
            return;

        _editorReady = ready;
        StateHasChanged();
    }

    private async Task RefreshAiStatusAsync()
    {
        try
        {
            var raw = await Js.InvokeAsync<string>("gf2ExerciseAi.getStatus");
            var status = JsonSerializer.Deserialize<ExerciseAiStatusResponse>(raw, JsonOpts);
            _aiEnabled = status?.Enabled == true;
            _aiRequiresLogin = status?.RequiresLogin == true;
            _aiStatusHint = status?.Enabled == true
                ? "AI-hjælp"
                : (status?.Message ?? "OpenAI-nøgle mangler på serveren");
        }
        catch
        {
            _aiEnabled = false;
            _aiRequiresLogin = false;
            _aiStatusHint = "Kunne ikke kontakte serveren for AI-status";
        }
    }

    private string LoginUrl =>
        "/auth/login?returnUrl=" + Uri.EscapeDataString(Navigation.Uri);

    private async Task GetHintAsync()
    {
        if (_editor is null || !_aiEnabled)
            return;

        _aiHintLoading = true;
        _aiBusy = true;
        _aiError = null;
        _aiHint = null;

        try
        {
            var payload = await BuildAiRequestAsync();
            var envelope = await PostAiAsync("gf2ExerciseAi.postHint", payload)
                ?? await PostAiViaHttpAsync("/api/exercise-ai/hint", payload);
            if (envelope is null)
            {
                _aiError = "Kunne ikke hente AI-tip — tomt svar.";
                return;
            }

            if (envelope.Ok && TryParseBody(envelope.Body, out ExerciseAiHintResponse? hint) && !string.IsNullOrWhiteSpace(hint?.Message))
            {
                _aiHint = hint.Message;
                return;
            }

            _aiError = FormatAiPostError(envelope);
        }
        catch (Exception ex)
        {
            _aiError = "Kunne ikke hente AI-tip: " + ex.Message;
        }
        finally
        {
            _aiHintLoading = false;
            _aiBusy = false;
            StateHasChanged();
        }
    }

    private async Task CheckSolutionAsync()
    {
        if (_editor is null || !_aiEnabled)
            return;

        _aiCheckLoading = true;
        _aiBusy = true;
        _aiError = null;
        _aiCheck = null;

        try
        {
            var payload = await BuildAiRequestAsync();
            var envelope = await PostAiAsync("gf2ExerciseAi.postCheck", payload)
                ?? await PostAiViaHttpAsync("/api/exercise-ai/check", payload);
            if (envelope is null)
            {
                _aiError = "Kunne ikke tjekke løsningen — tomt svar.";
                return;
            }

            if (envelope.Ok && TryParseBody(envelope.Body, out ExerciseAiCheckResult? check) && check is not null)
            {
                _aiCheck = check;
                return;
            }

            _aiError = FormatAiPostError(envelope);
        }
        catch (Exception ex)
        {
            _aiError = "Kunne ikke tjekke løsningen: " + ex.Message;
        }
        finally
        {
            _aiCheckLoading = false;
            _aiBusy = false;
            StateHasChanged();
        }
    }

    private async Task<AiPostEnvelope?> PostAiAsync(string jsMethod, object payload)
    {
        try
        {
            var raw = await Js.InvokeAsync<string>(jsMethod, payload);
            if (string.IsNullOrWhiteSpace(raw))
                return null;

            var envelope = JsonSerializer.Deserialize<AiPostEnvelope>(raw, JsonOpts);
            if (envelope is { Ok: false, Status: 0 })
                return null;
            return envelope;
        }
        catch
        {
            return null;
        }
    }

    private async Task<AiPostEnvelope?> PostAiViaHttpAsync(string path, ExerciseAiRequestPayload payload)
    {
        try
        {
            var client = HttpClientFactory.CreateClient("GF2LearnApi");
            using var response = await client.PostAsJsonAsync(path, payload);
            var body = await response.Content.ReadAsStringAsync();
            return new AiPostEnvelope
            {
                Ok = response.IsSuccessStatusCode,
                Status = (int)response.StatusCode,
                Body = body
            };
        }
        catch
        {
            return null;
        }
    }

    private static bool TryParseBody<T>(string? body, out T? value)
    {
        value = default;
        if (string.IsNullOrWhiteSpace(body))
            return false;

        try
        {
            value = JsonSerializer.Deserialize<T>(body, JsonOpts);
            return value is not null;
        }
        catch
        {
            return false;
        }
    }

    private static string FormatAiPostError(AiPostEnvelope result)
    {
        if (!string.IsNullOrWhiteSpace(result.Error))
        {
            if (result.Error.Contains("Failed to fetch", StringComparison.OrdinalIgnoreCase))
                return "Netværksfejl mod serveren. Log ud og ind igen efter deploy. Hvis det fortsætter: tjek at du er logget ind, og at proxy-timeout er mindst 120 sek.";
            return result.Error;
        }

        if (result.Status == 401)
            return "Log ind for at bruge AI-hjælpen. Hvis du lige har været logget ind, er sessionen udløbet.";

        if (result.Status == 400)
            return "AI kunne ikke læse koden. Skriv lidt kode i editoren og prøv igen.";

        if (result.Status == 503)
            return "AI er ikke konfigureret på serveren.";

        if (!string.IsNullOrWhiteSpace(result.Body))
        {
            if (result.Body.TrimStart().StartsWith('{'))
            {
                try
                {
                    using var doc = JsonDocument.Parse(result.Body);
                    if (doc.RootElement.TryGetProperty("detail", out var detail))
                    {
                        var text = detail.GetString();
                        if (!string.IsNullOrWhiteSpace(text))
                            return text;
                    }
                }
                catch
                {
                    // ignore parse errors
                }
            }
            else if (result.Body.Length < 280)
            {
                return result.Body;
            }
        }

        if (result.Ok)
            return "AI svarede, men svaret kunne ikke læses. Prøv igen.";

        return result.Status > 0
            ? $"AI-fejl (HTTP {result.Status})."
            : "AI-fejl — prøv igen.";
    }

    private async Task<ExerciseAiRequestPayload> BuildAiRequestAsync()
    {
        var code = await _editor!.GetCodeAsync();
        return new ExerciseAiRequestPayload(
            ContentSlug,
            PartIndex,
            code,
            _editor.LastConsoleOutput);
    }

    private async Task LoadVersionsAsync(bool selectLatest = false)
    {
        _versionLoading = true;
        try
        {
            var client = HttpClientFactory.CreateClient("GF2LearnApi");
            var response = await client.GetAsync(
                $"/api/progress/exercise/{Uri.EscapeDataString(ContentSlug)}/parts/{PartIndex}/versions");

            if (!response.IsSuccessStatusCode)
                return;

            var loaded = await response.Content.ReadFromJsonAsync<List<ExercisePartVersionDto>>(JsonOpts);
            if (loaded is null || loaded.Count == 0)
                return;

            _versions = loaded
                .Where(v => v.Id > 0 && !string.IsNullOrWhiteSpace(v.AnswerText))
                .ToList();

            if (_versions.Count == 0)
                return;

            if (selectLatest
                || string.IsNullOrEmpty(_selectedVersionKey)
                || _versions.All(v => v.Id.ToString() != _selectedVersionKey))
            {
                _selectedVersionKey = _versions[0].Id.ToString(CultureInfo.InvariantCulture);
            }

            _saved = true;
        }
        catch
        {
            // SavedCode from server may still apply on first paint
        }
        finally
        {
            _versionLoading = false;
            StateHasChanged();
        }
    }

    private async Task OnVersionSelectedAfterBindAsync()
    {
        if (!long.TryParse(_selectedVersionKey, NumberStyles.Integer, CultureInfo.InvariantCulture, out var versionId))
            return;

        await ApplyVersionToEditorAsync(versionId);
    }

    private async Task ApplyVersionToEditorAsync(long versionId)
    {
        if (_editor is null)
            return;

        if (!await _editor.WaitForEditorReadyAsync())
        {
            _saveError = "Editoren er ikke klar endnu — prøv igen om et øjeblik.";
            return;
        }

        var version = _versions.FirstOrDefault(v => v.Id == versionId);
        if (version is null)
            return;

        await _editor.SetCodeAsync(version.AnswerText ?? "");
        _saved = true;
        _saveError = null;
        StateHasChanged();
    }

    private static string FormatVersionLabel(int index, DateTimeOffset savedAt)
    {
        var local = savedAt.ToLocalTime();
        var stamp = local.ToString("d/M HH:mm", CultureInfo.InvariantCulture);
        return index == 0 ? $"Seneste ({stamp})" : $"Ældre {index + 1} ({stamp})";
    }

    private async Task FormatCodeAsync()
    {
        if (_editor is null)
        {
            _formatError = "Editoren er ikke klar endnu.";
            return;
        }

        if (!await _editor.WaitForEditorReadyAsync())
        {
            _formatError = "Editoren indlæses stadig — vent et øjeblik og prøv igen.";
            return;
        }

        _formatting = true;
        _formatError = null;
        StateHasChanged();

        try
        {
            var ok = await _editor.FormatDocumentAsync();
            if (!ok)
                _formatError = "Kunne ikke formatere — ret syntaksfejl og prøv igen.";
        }
        finally
        {
            _formatting = false;
            StateHasChanged();
        }
    }

    private async Task SaveAsync()
    {
        if (_editor is null)
        {
            _saveError = "Editoren er ikke klar endnu.";
            return;
        }

        if (!await _editor.WaitForEditorReadyAsync())
        {
            _saveError = "Editoren indlæses stadig — vent et øjeblik og prøv igen.";
            return;
        }

        _saving = true;
        _saveError = null;
        StateHasChanged();

        try
        {
            var code = await _editor.GetCodeAsync();
            if (string.IsNullOrWhiteSpace(code.Trim()))
            {
                _saveError = "Skriv noget kode før du gemmer.";
                return;
            }

            var client = HttpClientFactory.CreateClient("GF2LearnApi");
            using var response = await client.PostAsJsonAsync(
                "/api/progress/exercise",
                new SaveExercisePartPayload(ContentSlug, PartIndex, code));

            if (response.IsSuccessStatusCode)
            {
                var saved = await response.Content.ReadFromJsonAsync<ExercisePartVersionDto>(JsonOpts);
                if (saved is not null)
                    MergeSavedVersion(saved);

                await LoadVersionsAsync(selectLatest: true);
                _saved = true;
                await OnSaved.InvokeAsync();
                return;
            }

            if (response.StatusCode == HttpStatusCode.BadRequest)
            {
                _saveError = await ReadErrorDetailAsync(response) ?? "Kunne ikke gemme løsningen.";
                return;
            }

            if (response.StatusCode == HttpStatusCode.Unauthorized)
            {
                var jsOk = await Js.InvokeAsync<bool>(
                    "gf2ExerciseProgress.savePart",
                    ContentSlug,
                    PartIndex,
                    code);
                if (jsOk)
                {
                    _saved = true;
                    await LoadVersionsAsync(selectLatest: true);
                    await OnSaved.InvokeAsync();
                    return;
                }
            }

            _saveError = response.StatusCode switch
            {
                HttpStatusCode.Unauthorized =>
                    "Du er ikke logget ind — log ind og prøv igen.",
                HttpStatusCode.ServiceUnavailable =>
                    "Gem er ikke tilgængelig (database mangler på serveren).",
                HttpStatusCode.NotFound =>
                    "Gem-endpoint findes ikke — tjek at serveren er opdateret.",
                _ => $"Kunne ikke gemme (HTTP {(int)response.StatusCode})."
            };
        }
        catch (Exception)
        {
            _saveError = "Kunne ikke gemme — netværksfejl. Prøv igen.";
        }
        finally
        {
            _saving = false;
            StateHasChanged();
        }
    }

    private void MergeSavedVersion(ExercisePartVersionDto saved)
    {
        if (string.IsNullOrWhiteSpace(saved.AnswerText))
            return;

        _versions.RemoveAll(v => v.Id == saved.Id);
        _versions.Insert(0, saved);
        if (_versions.Count > 3)
            _versions = _versions.Take(3).ToList();

        _selectedVersionKey = saved.Id.ToString(CultureInfo.InvariantCulture);
    }

    private static async Task<string?> ReadErrorDetailAsync(HttpResponseMessage response)
    {
        try
        {
            var body = await response.Content.ReadAsStringAsync();
            if (string.IsNullOrWhiteSpace(body))
                return null;

            using var doc = JsonDocument.Parse(body);
            if (doc.RootElement.TryGetProperty("detail", out var detail))
                return detail.GetString();
        }
        catch
        {
            // ignore parse errors
        }

        return null;
    }

    private sealed record SaveExercisePartPayload(string ContentSlug, int PartIndex, string? AnswerText);
    private sealed record ExerciseAiRequestPayload(string ContentSlug, int PartIndex, string StudentCode, string? ConsoleOutput);
    private sealed record ExerciseAiHintResponse(string Message);
    private sealed record ExerciseAiCheckResult(
        [property: JsonPropertyName("isSolved")] bool IsSolved,
        [property: JsonPropertyName("feedback")] string Feedback);
    private sealed record ExerciseAiStatusResponse(
        [property: JsonPropertyName("enabled")] bool Enabled,
        [property: JsonPropertyName("message")] string? Message,
        [property: JsonPropertyName("requiresLogin")] bool RequiresLogin);

    private sealed class AiPostEnvelope
    {
        [JsonPropertyName("ok")]
        public bool Ok { get; set; }

        [JsonPropertyName("status")]
        public int Status { get; set; }

        [JsonPropertyName("body")]
        public string? Body { get; set; }

        [JsonPropertyName("error")]
        public string? Error { get; set; }
    }
}
