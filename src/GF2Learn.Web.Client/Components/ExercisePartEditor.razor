@using System.Net
@using System.Net.Http.Json
@using System.Text.Json
@using System.Text.Json.Serialization
@inject IHttpClientFactory HttpClientFactory
@inject IJSRuntime Js

<CodePlaygroundCore @ref="_editor"
                    InitialCode="@InitialCode"
                    SavedCode="@SavedCode"
                    WrapExerciseMethod="true"
                    Title="Skriv din løsning her"
                    RunLabel="Kør"
                    ResetLabel="Nulstil"
                    EmptyOutputHint="Skriv koden efter // TODO-linjen og tryk Kør."
                    RootClass="exercise-ide-playground"
                    EditorHostClass="playground-editor-host-exercise"
                    ShowCopyButton="false">
    <Footer>
        <div class="exercise-ide-footer">
            <div class="exercise-ide-actions">
                <button type="button"
                        class="btn btn-ghost btn-sm exercise-ai-btn"
                        disabled="@(!_aiEnabled || _aiBusy)"
                        title="@_aiStatusHint"
                        @onclick="GetHintAsync">
                    @(_aiHintLoading ? "Henter tip…" : "AI hjælp mig")
                </button>
                <button type="button"
                        class="btn btn-ghost btn-sm exercise-ai-btn"
                        disabled="@(!_aiEnabled || _aiBusy)"
                        title="@_aiStatusHint"
                        @onclick="CheckSolutionAsync">
                    @(_aiCheckLoading ? "Tjekker…" : "Er opgaven løst?")
                </button>
                <button type="button" class="btn btn-primary btn-sm" disabled="@_saving" @onclick="SaveAsync">
                    @(_saving ? "Gemmer…" : _saved ? "Gemt ✓" : "Gem som løst")
                </button>
            </div>
            @if (!string.IsNullOrWhiteSpace(_saveError))
            {
                <span class="exercise-ide-save-error">@_saveError</span>
            }
            @if (!string.IsNullOrWhiteSpace(_aiError))
            {
                <span class="exercise-ide-save-error">@_aiError</span>
            }
        </div>
        @if (!string.IsNullOrWhiteSpace(_aiHint))
        {
            <div class="exercise-ai-panel exercise-ai-panel-hint" role="status">
                <p class="exercise-ai-panel-label">AI-tip</p>
                <p class="exercise-ai-panel-body">@_aiHint</p>
            </div>
        }
        @if (_aiCheck is not null)
        {
            <div class="exercise-ai-panel @(_aiCheck.IsSolved ? "exercise-ai-panel-ok" : "exercise-ai-panel-warn")" role="status">
                <p class="exercise-ai-panel-label">@(_aiCheck.IsSolved ? "Opgaven ser løst ud" : "Ikke helt i mål endnu")</p>
                <p class="exercise-ai-panel-body">@_aiCheck.Feedback</p>
            </div>
        }
    </Footer>
</CodePlaygroundCore>

@code {
    [Parameter, EditorRequired] public string ContentSlug { get; set; } = "";
    [Parameter] public int PartIndex { get; set; }
    [Parameter, EditorRequired] public string InitialCode { get; set; } = "";
    [Parameter] public string? SavedCode { get; set; }
    [Parameter] public EventCallback OnSaved { get; set; }

    private CodePlaygroundCore? _editor;
    private bool _saved;
    private bool _saving;
    private string? _saveError;

    private bool _aiEnabled;
    private bool _aiBusy;
    private bool _aiHintLoading;
    private bool _aiCheckLoading;
    private string? _aiStatusHint;
    private string? _aiError;
    private string? _aiHint;
    private ExerciseAiCheckResult? _aiCheck;

    protected override void OnParametersSet() =>
        _saved = !string.IsNullOrWhiteSpace(SavedCode);

    protected override async Task OnInitializedAsync() => await RefreshAiStatusAsync();

    private async Task RefreshAiStatusAsync()
    {
        try
        {
            var status = await Js.InvokeAsync<ExerciseAiStatusResponse>("gf2ExerciseAi.getStatus");
            _aiEnabled = status?.Enabled == true;
            _aiStatusHint = status?.Enabled == true
                ? "AI-hjælp"
                : (status?.Message ?? "OpenAI-nøgle mangler på serveren");
        }
        catch
        {
            _aiEnabled = false;
            _aiStatusHint = "Kunne ikke kontakte serveren for AI-status";
        }
    }

    private async Task GetHintAsync()
    {
        if (_editor is null || !_aiEnabled)
            return;

        _aiHintLoading = true;
        _aiBusy = true;
        _aiError = null;
        _aiHint = null;
        StateHasChanged();

        try
        {
            var payload = await BuildAiRequestAsync();
            var result = await Js.InvokeAsync<AiPostResult>("gf2ExerciseAi.postHint", payload);

            if (result.Ok && result.Data is { ValueKind: JsonValueKind.Object } data)
            {
                var hint = JsonSerializer.Deserialize<ExerciseAiHintResponse>(data.GetRawText());
                _aiHint = hint?.Message;
                if (!string.IsNullOrWhiteSpace(_aiHint))
                    return;
            }

            _aiError = FormatAiPostError(result);
        }
        catch (Exception ex)
        {
            _aiError = "Kunne ikke hente AI-tip: " + ex.Message;
        }
        finally
        {
            _aiHintLoading = false;
            _aiBusy = false;
            StateHasChanged();
        }
    }

    private async Task CheckSolutionAsync()
    {
        if (_editor is null || !_aiEnabled)
            return;

        _aiCheckLoading = true;
        _aiBusy = true;
        _aiError = null;
        _aiCheck = null;
        StateHasChanged();

        try
        {
            var payload = await BuildAiRequestAsync();
            var result = await Js.InvokeAsync<AiPostResult>("gf2ExerciseAi.postCheck", payload);

            if (result.Ok && result.Data is { ValueKind: JsonValueKind.Object } data)
            {
                _aiCheck = JsonSerializer.Deserialize<ExerciseAiCheckResult>(data.GetRawText());
                if (_aiCheck is not null)
                    return;
            }

            _aiError = FormatAiPostError(result);
        }
        catch (Exception ex)
        {
            _aiError = "Kunne ikke tjekke løsningen: " + ex.Message;
        }
        finally
        {
            _aiCheckLoading = false;
            _aiBusy = false;
            StateHasChanged();
        }
    }

    private static string FormatAiPostError(AiPostResult result)
    {
        if (result.Status == 401)
            return "Log ind igen for at bruge AI (session udløbet efter deploy).";

        if (result.Status == 503)
            return "AI er ikke konfigureret på serveren.";

        if (result.Data is { ValueKind: JsonValueKind.Object } data)
        {
            var detail = TryReadProblemDetail(data);
            if (!string.IsNullOrWhiteSpace(detail))
                return detail;
        }

        if (!string.IsNullOrWhiteSpace(result.Text) && result.Text.Length < 280)
            return result.Text;

        return result.Status > 0
            ? $"AI-fejl (HTTP {result.Status})."
            : "AI-fejl — prøv igen.";
    }

    private static string? TryReadProblemDetail(JsonElement data)
    {
        if (data.TryGetProperty("detail", out var detail))
            return detail.GetString();
        if (data.TryGetProperty("title", out var title))
            return title.GetString();
        return null;
    }

    private async Task<ExerciseAiRequestPayload> BuildAiRequestAsync()
    {
        var code = await _editor!.GetCodeAsync();
        return new ExerciseAiRequestPayload(
            ContentSlug,
            PartIndex,
            code,
            _editor.LastConsoleOutput);
    }

    private async Task SaveAsync()
    {
        if (_editor is null)
            return;

        _saving = true;
        _saveError = null;
        StateHasChanged();

        try
        {
            var code = await _editor.GetCodeAsync();
            if (string.IsNullOrWhiteSpace(code.Trim()))
            {
                _saveError = "Skriv noget kode før du gemmer.";
                return;
            }

            var client = HttpClientFactory.CreateClient("GF2LearnApi");
            using var response = await client.PostAsJsonAsync(
                "/api/progress/exercise",
                new SaveExercisePartPayload(ContentSlug, PartIndex, code));

            if (response.IsSuccessStatusCode)
            {
                _saved = true;
                await OnSaved.InvokeAsync();
                return;
            }

            if (response.StatusCode == HttpStatusCode.Unauthorized)
            {
                var jsOk = await Js.InvokeAsync<bool>(
                    "gf2ExerciseProgress.savePart",
                    ContentSlug,
                    PartIndex,
                    code);
                if (jsOk)
                {
                    _saved = true;
                    await OnSaved.InvokeAsync();
                    return;
                }
            }

            _saveError = response.StatusCode switch
            {
                HttpStatusCode.Unauthorized =>
                    "Du er ikke logget ind — log ind og prøv igen.",
                HttpStatusCode.ServiceUnavailable =>
                    "Gem er ikke tilgængelig (database mangler på serveren).",
                HttpStatusCode.NotFound =>
                    "Gem-endpoint findes ikke — tjek at serveren er opdateret.",
                _ => $"Kunne ikke gemme (HTTP {(int)response.StatusCode})."
            };
        }
        catch (Exception)
        {
            _saveError = "Kunne ikke gemme — netværksfejl. Prøv igen.";
        }
        finally
        {
            _saving = false;
            StateHasChanged();
        }
    }

    private sealed record SaveExercisePartPayload(string ContentSlug, int PartIndex, string? AnswerText);
    private sealed record ExerciseAiRequestPayload(string ContentSlug, int PartIndex, string StudentCode, string? ConsoleOutput);
    private sealed record ExerciseAiHintResponse(string Message);
    private sealed record ExerciseAiCheckResult(
        [property: JsonPropertyName("isSolved")] bool IsSolved,
        [property: JsonPropertyName("feedback")] string Feedback);
    private sealed record ExerciseAiStatusResponse(
        [property: JsonPropertyName("enabled")] bool Enabled,
        [property: JsonPropertyName("message")] string? Message);

    private sealed class AiPostResult
    {
        [JsonPropertyName("ok")]
        public bool Ok { get; set; }

        [JsonPropertyName("status")]
        public int Status { get; set; }

        [JsonPropertyName("data")]
        public JsonElement Data { get; set; }

        [JsonPropertyName("text")]
        public string? Text { get; set; }
    }
}
