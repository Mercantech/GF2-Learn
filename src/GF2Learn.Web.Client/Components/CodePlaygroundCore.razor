@using Microsoft.JSInterop
@inject CSharpRunnerService Runner
@inject IJSRuntime Js
@implements IAsyncDisposable

<div class="code-playground code-playground-interactive @RootClass">
    <div class="playground-header">
        <span class="playground-title">@Title</span>
        @if (ShowRunToolbar)
        {
            <div class="playground-header-toolbar">
                @if (UseIconToolbar)
                {
                    <button type="button"
                            class="playground-icon-btn playground-icon-btn-run"
                            disabled="@_running"
                            title="@GetRunTitle()"
                            aria-label="@(_running ? "Kører kode" : GetRunTitle())"
                            @onclick="RunAsync">
                        @if (_running)
                        {
                            <span class="gf2-spinner" aria-hidden="true"></span>
                        }
                        else
                        {
                            <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor" aria-hidden="true">
                                <path d="M8 5v14l11-7z" />
                            </svg>
                        }
                    </button>
                    <button type="button"
                            class="playground-icon-btn"
                            disabled="@_running"
                            title="@ResetLabel"
                            aria-label="@ResetLabel"
                            @onclick="ResetCodeAsync">
                        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                            <path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8" />
                            <path d="M3 3v5h5" />
                        </svg>
                    </button>
                }
                else
                {
                    <button type="button" class="btn btn-primary btn-sm" disabled="@_running" @onclick="RunAsync">
                        @(_running ? "Kører…" : RunLabel)
                    </button>
                    <button type="button" class="btn btn-ghost btn-sm" disabled="@_running" @onclick="ResetCodeAsync">@ResetLabel</button>
                    @if (ShowCopyButton)
                    {
                        <button type="button" class="btn btn-ghost btn-sm" @onclick="CopyCodeAsync">Kopier</button>
                    }
                }
                @if (ToolbarActions is not null)
                {
                    @ToolbarActions
                }
            </div>
        }
    </div>

    <div id="@_editorId"
         class="playground-editor-host @EditorHostClass @(_monacoMounted ? "playground-editor-host-ready" : "playground-editor-host-loading")"
         data-pending-code="@_pendingCodeAttr"></div>

    @if (ShowOutputPanel)
    {
        <div class="playground-output-panel">
            <p class="playground-output-label">Output</p>
            @if (_running)
            {
                <p class="playground-output-muted">Kører kode…</p>
            }
            else if (!string.IsNullOrEmpty(_error))
            {
                <pre class="playground-output playground-output-error">@_error</pre>
            }
            else if (!string.IsNullOrEmpty(_output))
            {
                <pre class="playground-output @OutputClass">@_output</pre>
            }
            else
            {
                <p class="playground-output-muted">@EmptyOutputHint</p>
            }
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(ExpectedOutput))
    {
        <div class="playground-expected @ExpectedClass">
            <span class="playground-expected-label">Forventet</span>
            <span>@ExpectedOutput</span>
            @if (_expectedMatch == true)
            {
                <span class="playground-match-badge playground-match-ok">Match</span>
            }
            else if (_expectedMatch == false)
            {
                <span class="playground-match-badge playground-match-fail">Mismatch</span>
            }
        </div>
    }

    @if (_elapsed is not null)
    {
        <p class="playground-elapsed">@(_elapsed.Value.TotalMilliseconds.ToString("F0")) ms</p>
    }

    @if (Footer is not null)
    {
        <div class="playground-footer">@Footer</div>
    }
</div>

@code {
    [Parameter, EditorRequired] public string InitialCode { get; set; } = "";
    /// <summary>Gemt elevkode — bruges ved opstart i stedet for <see cref="InitialCode"/> (nulstil bruger stadig skabelon).</summary>
    [Parameter] public string? SavedCode { get; set; }
    [Parameter] public string ExpectedOutput { get; set; } = "";
    [Parameter] public IReadOnlyList<string> Refs { get; set; } = Array.Empty<string>();
    [Parameter] public bool WrapExerciseMethod { get; set; }
    [Parameter] public string Title { get; set; } = "Code playground";
    [Parameter] public string RunLabel { get; set; } = "Run";
    [Parameter] public string ResetLabel { get; set; } = "Reset";
    [Parameter] public string EmptyOutputHint { get; set; } = "Tryk Run for at køre din kode i browseren.";
    [Parameter] public string RootClass { get; set; } = "";
    [Parameter] public string EditorHostClass { get; set; } = "";
    [Parameter] public bool ShowCopyButton { get; set; } = true;
    [Parameter] public bool ShowRunToolbar { get; set; } = true;
    [Parameter] public bool UseIconToolbar { get; set; }
    [Parameter] public bool ShowOutputPanel { get; set; } = true;
    [Parameter] public bool EnableCtrlSave { get; set; }
    [Parameter] public EventCallback OnCtrlSave { get; set; }
    [Parameter] public RenderFragment? ToolbarActions { get; set; }
    [Parameter] public RenderFragment? Footer { get; set; }

    private readonly string _editorId = $"pg-{Guid.NewGuid():N}";
    private DotNetObjectReference<CodePlaygroundCore>? _ctrlSaveRef;
    private bool _ctrlSaveRegistered;
    private string _code = "";
    private string _output = "";
    private string _error = "";
    private bool _running;
    private bool _editorReady;
    private bool _monacoMounted;
    private bool _startupCodeApplied;
    private string? _syncedInitialCode;
    private string _pendingCodeAttr = "";
    private bool? _expectedMatch;
    private TimeSpan? _elapsed;
    private static int _compilerWarmupStarted;

    private string OutputClass => _expectedMatch switch
    {
        true => "playground-output-ok",
        false => "playground-output-warn",
        _ => ""
    };

    private string ExpectedClass => _expectedMatch switch
    {
        true => "playground-expected-ok",
        false => "playground-expected-fail",
        _ => ""
    };

    private string StartupCode =>
        string.IsNullOrWhiteSpace(SavedCode) ? InitialCode : SavedCode;

    protected override void OnParametersSet()
    {
        var startup = StartupCode;
        if (_syncedInitialCode is null || startup != _syncedInitialCode)
            _code = startup;

        _pendingCodeAttr = EncodePendingCode(startup);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            if (_editorReady && !_startupCodeApplied)
                await ApplyStartupCodeOnceAsync();

            return;
        }

        if (_editorReady)
            return;

        _ctrlSaveRef ??= DotNetObjectReference.Create(this);

        try
        {
            await Js.InvokeVoidAsync("gf2Playground.init", _editorId, StartupCode);
        }
        finally
        {
            try
            {
                await Js.InvokeVoidAsync("gf2ExercisePage.checkReady");
            }
            catch
            {
                /* exercise-page-load.js may not be loaded on all hosts */
            }
        }

        _editorReady = await WaitForEditorReadyAsync();
        _monacoMounted = _editorReady;
        await ApplyStartupCodeOnceAsync();

        if (EnableCtrlSave && OnCtrlSave.HasDelegate)
            await RegisterCtrlSaveAsync();

        if (ShowRunToolbar)
            await RegisterCtrlRunAsync();

        if (Interlocked.CompareExchange(ref _compilerWarmupStarted, 1, 0) == 0)
            _ = Runner.WarmupAsync();

        StateHasChanged();
    }

    private async Task ApplyStartupCodeOnceAsync()
    {
        if (_startupCodeApplied)
            return;

        await SetCodeAsync(StartupCode);
        _startupCodeApplied = true;
    }

    public bool IsEditorReady => _editorReady;

    public async Task<bool> WaitForEditorReadyAsync(int maxWaitMs = 5000)
    {
        var deadline = Environment.TickCount64 + maxWaitMs;
        while (Environment.TickCount64 < deadline)
        {
            if (_editorReady)
            {
                try
                {
                    if (await Js.InvokeAsync<bool>("gf2Playground.isReady", _editorId))
                        return true;
                }
                catch
                {
                    return true;
                }
            }

            await Task.Delay(50);
        }

        return _editorReady;
    }

    private async Task RegisterCtrlSaveAsync()
    {
        if (_ctrlSaveRegistered)
            return;

        _ctrlSaveRef ??= DotNetObjectReference.Create(this);
        await Js.InvokeVoidAsync("gf2Playground.registerCtrlSave", _editorId, _ctrlSaveRef);
        _ctrlSaveRegistered = true;
    }

    private bool _ctrlRunRegistered;

    private async Task RegisterCtrlRunAsync()
    {
        if (_ctrlRunRegistered)
            return;

        _ctrlSaveRef ??= DotNetObjectReference.Create(this);
        await Js.InvokeVoidAsync("gf2Playground.registerCtrlRun", _editorId, _ctrlSaveRef);
        _ctrlRunRegistered = true;
    }

    private string GetRunTitle() =>
        UseIconToolbar ? $"{RunLabel} (Ctrl+Enter)" : RunLabel;

    [JSInvokable]
    public Task TriggerCtrlSaveAsync() =>
        InvokeAsync(async () =>
        {
            if (OnCtrlSave.HasDelegate)
                await OnCtrlSave.InvokeAsync();
        });

    [JSInvokable]
    public Task TriggerCtrlRunAsync() =>
        InvokeAsync(async () =>
        {
            if (!_running)
                await RunAsync();
        });

    private static string EncodePendingCode(string code) =>
        Convert.ToBase64String(System.Text.Encoding.UTF8.GetBytes(code));

    public async Task<string> GetCodeAsync()
    {
        if (!await WaitForEditorReadyAsync())
            return _code;

        try
        {
            var value = await Js.InvokeAsync<string>("gf2Playground.getValue", _editorId);
            if (!string.IsNullOrEmpty(value))
                _code = value;
            return value;
        }
        catch
        {
            return _code;
        }
    }

    public string? LastOutput => string.IsNullOrEmpty(_output) ? null : _output;
    public string? LastError => string.IsNullOrEmpty(_error) ? null : _error;
    public string? LastConsoleOutput =>
        !string.IsNullOrEmpty(_error) ? _error : LastOutput;

    public async Task SetCodeAsync(string code)
    {
        _code = code;
        _syncedInitialCode = code;
        if (_editorReady)
            await Js.InvokeVoidAsync("gf2Playground.setValue", _editorId, code);
    }

    public async Task<bool> FormatDocumentAsync()
    {
        if (!_editorReady)
            return false;

        try
        {
            return await Js.InvokeAsync<bool>("gf2Playground.formatDocument", _editorId);
        }
        catch
        {
            return false;
        }
    }

    private async Task RunAsync()
    {
        _running = true;
        _error = "";
        _output = "";
        _expectedMatch = null;
        _elapsed = null;
        if (_editorReady)
            await Js.InvokeVoidAsync("gf2Playground.setReadOnly", _editorId, true);
        StateHasChanged();

        try
        {
            _code = await GetCodeAsync();
            var result = await Runner.RunAsync(
                _code,
                ExpectedOutput,
                Refs,
                stdinOverride: null,
                showStdinTraceInOutput: true,
                wrapExerciseMethod: WrapExerciseMethod);

            _elapsed = result.Elapsed;
            if (result.Success)
            {
                _output = result.Output;
                _expectedMatch = result.ExpectedMatch;
            }
            else
            {
                _error = result.Error ?? "Ukendt fejl.";
            }
        }
        finally
        {
            _running = false;
            if (_editorReady)
                await Js.InvokeVoidAsync("gf2Playground.setReadOnly", _editorId, false);
        }
    }

    private async Task ResetCodeAsync()
    {
        await SetCodeAsync(InitialCode);
        _output = "";
        _error = "";
        _expectedMatch = null;
        _elapsed = null;
    }

    private async Task CopyCodeAsync()
    {
        var code = await GetCodeAsync();
        await Js.InvokeVoidAsync("navigator.clipboard.writeText", code);
    }

    public async ValueTask DisposeAsync()
    {
        _ctrlSaveRef?.Dispose();
        if (_editorReady)
            await Js.InvokeVoidAsync("gf2Playground.dispose", _editorId);
    }
}
