@inject CSharpRunnerService Runner

<div class="console-app @(_hasRun ? "console-app-has-run" : "")">
    <div class="console-app-titlebar" aria-hidden="true">
        <span class="console-app-dot"></span>
        <span class="console-app-dot"></span>
        <span class="console-app-dot"></span>
        <span class="console-app-title">@WindowTitle</span>
    </div>

    <div class="console-app-body">
        <pre class="console-app-screen" aria-live="polite">@_screenText</pre>

        @if (_usesReadLine && _stdinFields.Count > 0)
        {
            <div class="console-app-stdin">
                <p class="console-app-stdin-label">Simuleret tastatur</p>
                <p class="console-app-stdin-hint">
                    Programmet pauser ved hvert <code>Console.ReadLine()</code> og venter på tekst fra tastaturet.
                    Her skriver I svarene på forhånd, i den rækkefølge programmet beder om dem.
                </p>
                <ul class="console-app-stdin-legend">
                    <li><code class="console-app-stdin-var console-app-stdin-var-inline">valg</code> = variablen i koden (fx <code>var valg = Console.ReadLine()</code>)</li>
                    <li><span class="console-app-stdin-prompt console-app-stdin-prompt-inline">Dit valg:</span> = teksten programmet lige har skrevet med <code>Console.Write</code></li>
                </ul>
                <ol class="console-app-stdin-list">
                    @for (var i = 0; i < _stdinFields.Count; i++)
                    {
                        var index = i;
                        var field = _stdinFields[index];
                        <li>
                            <label class="console-app-stdin-field">
                                <span class="console-app-stdin-meta">
                                    <span class="console-app-stdin-step">@(index + 1)</span>
                                    @if (!string.IsNullOrWhiteSpace(field.VariableName))
                                    {
                                        <code class="console-app-stdin-var">@field.VariableName</code>
                                    }
                                    else
                                    {
                                        <span class="console-app-stdin-var-fallback">input @(index + 1)</span>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(field.Prompt))
                                    {
                                        <span class="console-app-stdin-prompt">@field.Prompt</span>
                                    }
                                </span>
                                <input type="text"
                                       class="console-app-stdin-input"
                                       @bind="field.Value"
                                       @bind:event="oninput"
                                       disabled="@_running"
                                       aria-label="@GetInputAriaLabel(field, index)" />
                            </label>
                        </li>
                    }
                </ol>
            </div>
        }

        <div class="console-app-toolbar">
            <button type="button" class="btn btn-primary btn-sm" disabled="@_running" @onclick="RunAsync">
                @(_running ? "Kører…" : _hasRun ? "Kør igen" : "Start program")
            </button>
            @if (_usesReadLine && _stdinFields.Count > 0)
            {
                <button type="button" class="btn btn-ghost btn-sm" disabled="@_running" @onclick="ResetInputs">
                    Nulstil input
                </button>
            }
        </div>
    </div>
</div>

@code {
    [Parameter, EditorRequired] public string Code { get; set; } = "";
    [Parameter] public string WindowTitle { get; set; } = "Konsol-app.exe";

    private readonly List<StdinFieldModel> _stdinFields = [];
    private List<StdinFieldModel> _defaultStdin = [];
    private bool _usesReadLine;
    private string _screenText = "";
    private bool _running;
    private bool _hasRun;
    private bool _pendingAutoRun;

    protected override void OnParametersSet()
    {
        if (_stdinFields.Count > 0)
            return;

        var prepared = PlaygroundSourceBuilder.Prepare(Code);
        _usesReadLine = prepared.UsesReadLine;
        _defaultStdin = PlaygroundSourceBuilder.GetSimulatedStdinFields(Code)
            .Select(f => new StdinFieldModel(f.Value, f.VariableName, f.Prompt))
            .ToList();
        _stdinFields.AddRange(_defaultStdin.Select(CloneField));
        _pendingAutoRun = true;
        _screenText = "Tryk «Start program» for at køre reference-løsningen…";
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!_pendingAutoRun)
            return;

        _pendingAutoRun = false;
        await RunAsync();
    }

    private async Task RunAsync()
    {
        _running = true;
        _hasRun = true;
        _screenText = "Kører…";
        StateHasChanged();

        try
        {
            var stdin = _usesReadLine ? (IReadOnlyList<string>)_stdinFields.Select(f => f.Value).ToList() : null;
            var result = await Runner.RunAsync(
                Code,
                expectedOutput: null,
                extraRefs: [],
                stdinOverride: stdin,
                showStdinTraceInOutput: false);

            if (result.Success)
                _screenText = string.IsNullOrEmpty(result.Output) ? "(ingen output)" : result.Output;
            else
                _screenText = result.Error ?? "Ukendt fejl.";
        }
        finally
        {
            _running = false;
            StateHasChanged();
        }
    }

    private void ResetInputs()
    {
        _stdinFields.Clear();
        _stdinFields.AddRange(_defaultStdin.Select(CloneField));
    }

    private static string GetInputAriaLabel(StdinFieldModel field, int index)
    {
        if (!string.IsNullOrWhiteSpace(field.VariableName))
            return field.VariableName + (field.Prompt is null ? "" : ", " + field.Prompt);
        return "Input " + (index + 1);
    }

    private static StdinFieldModel CloneField(StdinFieldModel f) =>
        new(f.Value, f.VariableName, f.Prompt);

    private sealed class StdinFieldModel(string value, string? variableName, string? prompt)
    {
        public string Value { get; set; } = value;
        public string? VariableName { get; set; } = variableName;
        public string? Prompt { get; set; } = prompt;
    }
}
