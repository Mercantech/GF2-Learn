
<div class="project-demo-card bibliotek-demo">
    <header class="bib-hero">
        <div class="bib-hero-icon" aria-hidden="true">📚</div>
        <div>
            <p class="bib-hero-eyebrow">Reference · MVP</p>
            <h3 class="bib-hero-title">Bibliotek</h3>
            <p class="bib-hero-lead">Udlån og returnér bøger — som menu 3 og 4 i jeres konsol-aflevering.</p>
        </div>
    </header>

    <div class="bib-stats">
        <div class="bib-stat bib-stat-available">
            <span class="bib-stat-value">@AvailableCount</span>
            <span class="bib-stat-label">Ledige</span>
        </div>
        <div class="bib-stat bib-stat-loaned">
            <span class="bib-stat-value">@LoanedCount</span>
            <span class="bib-stat-label">Udlånte</span>
        </div>
        <div class="bib-stat bib-stat-total">
            <span class="bib-stat-value">@_books.Count</span>
            <span class="bib-stat-label">Bøger</span>
        </div>
    </div>

    <div class="bib-list-wrap">
        <h4 class="bib-form-title">Hylden</h4>
        @if (_books.Count == 0)
        {
            <p class="bib-empty">Ingen bøger i biblioteket.</p>
        }
        else
        {
            <ul class="bib-list">
                @foreach (var book in _books)
                {
                    <li class="bib-item @(book.Loaned ? "bib-item--loaned" : null)">
                        <div class="bib-item-main">
                            <span class="bib-item-icon" aria-hidden="true">@(book.Loaned ? "🔒" : "📖")</span>
                            <div>
                                <strong class="bib-item-title">@book.Title</strong>
                                <span class="bib-item-author">@book.Author</span>
                            </div>
                        </div>
                        <span class="bib-badge @(book.Loaned ? "bib-badge--loaned" : "bib-badge--available")">
                            @(book.Loaned ? "Udlånt" : "Ledig")
                        </span>
                        @if (!book.Loaned)
                        {
                            <button type="button" class="btn btn-primary btn-sm" @onclick="() => Loan(book)">Udlån</button>
                        }
                        else
                        {
                            <button type="button" class="btn btn-ghost btn-sm" @onclick="() => ReturnBook(book)">Returnér</button>
                        }
                    </li>
                }
            </ul>
        }
    </div>

    @if (_message is not null)
    {
        <p class="bib-feedback bib-feedback--info">@_message</p>
    }

    <p class="bib-tip">
        I konsollen: lav <code>Book</code> og <code>Library</code> med <code>List&lt;Book&gt;</code> og tjek om bogen er ledig før udlån.
    </p>
</div>

@code {
    private sealed class Book
    {
        public string Title { get; set; } = "";
        public string Author { get; set; } = "";
        public bool Loaned { get; set; }
    }

    private string? _message;
    private readonly List<Book> _books =
    [
        new() { Title = "C# for begyndere", Author = "Mercantec" },
        new() { Title = "Clean Code", Author = "Robert C. Martin", Loaned = true }
    ];

    private int AvailableCount => _books.Count(b => !b.Loaned);
    private int LoanedCount => _books.Count(b => b.Loaned);

    private void Loan(Book book)
    {
        if (book.Loaned) return;
        book.Loaned = true;
        _message = $"«{book.Title}» er udlånt.";
    }

    private void ReturnBook(Book book)
    {
        if (!book.Loaned) return;
        book.Loaned = false;
        _message = $"«{book.Title}» er returneret og ledig igen.";
    }
}
