@using GF2Learn.Web.Client.Components.ProjectDemos
@using GF2Learn.Web.Client.Models

@if (Slug == "projekt-log-parser")
{
    <section class="project-solution-section">
        <h2 class="project-solution-heading">Eksempel-logfiler</h2>
        <p class="project-solution-note">
            Download de tre logfiler til jeres eget projekt (med i GitHub som pensum kræver).
            De indeholder <strong>de samme 8 hændelser</strong> i txt-, JSON- og CSV-format.
        </p>
        <ul class="lp-solution-downloads">
            @foreach (var file in LogParserSamples.Files)
            {
                <li>
                    <a class="lp-solution-download-link" href="@LogParserSamples.Url(file.FileName)" download="@file.FileName">
                        <span class="lp-solution-download-name">@file.FileName</span>
                        <span class="lp-solution-download-desc">@file.Description</span>
                    </a>
                </li>
            }
        </ul>
        <p class="project-solution-note-muted">
            Konsol-demoen og Blazor-demos indlæser samme filer. I jeres program: læg dem i projektmappen og brug <code>File.ReadAllLines</code> / <code>File.ReadAllText</code>.
        </p>
    </section>
}

@if (!string.IsNullOrWhiteSpace(ConsoleCode))
{
    <section class="project-solution-section">
        <h2 class="project-solution-heading">Konsol-reference (kør program)</h2>
        <div class="project-solution-console-intro">
            <p class="project-solution-note">
                Her kører I <strong>reference-løsningen</strong> som en færdig konsol-app (<code>.exe</code>) i browseren —
                uden at se C#-koden. Programmet viser menu og output; du svarer <strong>ét trin ad gangen</strong> nederst.
            </p>
            <ul class="project-solution-console-steps">
                <li>Tryk <strong>Start program</strong> — menuen vises i terminalen.</li>
                <li>Skriv dit svar i feltet (fx menuvalg <code>1</code> eller en opgavetekst) og tryk <strong>Send</strong> eller Enter.</li>
                <li>Programmet kører videre efter hvert svar, indtil du er færdig.</li>
            </ul>
            @if (!string.IsNullOrWhiteSpace(ConsoleScenarioHint))
            {
                <p class="project-solution-scenario"><strong>Forslag til flow:</strong> @ConsoleScenarioHint</p>
            }
            <p class="project-solution-note-muted">
                Første start kan tage et øjeblik (C#-runtime indlæses i browseren). Til aflevering laver I jeres eget konsolprojekt i GitHub.
            </p>
        </div>
        <ProjectConsoleRunner Code="@ConsoleCode" WindowTitle="@ConsoleWindowTitle" />
    </section>
}

@if (ShowMvp || ShowExtended)
{
    <ProjectSolutionBlazorDemos Slug="@Slug" ShowMvp="ShowMvp" ShowExtended="ShowExtended" />
}

@code {
    [Parameter, EditorRequired] public string Slug { get; set; } = "";
    [Parameter] public string? ConsoleCode { get; set; }
    [Parameter] public bool ShowMvp { get; set; }
    [Parameter] public bool ShowExtended { get; set; }

    private string ConsoleWindowTitle => Slug switch
    {
        "projekt-1-hjemmespil" => "Tidsfordrivsspil.exe",
        "projekt-huskeliste" => "Huskeliste.exe",
        "projekt-jobsoegning" => "Jobsøgning-tracker.exe",
        "projekt-2-binaer" => "BinaerOmformer.exe",
        "projekt-bibliotek" => "Bibliotek.exe",
        "projekt-log-parser" => "LogParser.exe",
        _ => "Konsol-app.exe"
    };

    private string? ConsoleScenarioHint => Slug switch
    {
        "projekt-jobsoegning" =>
            "2 (vis) → 1 (tilføj) → firma/titel/status → 2 → 3 (afslut).",
        "projekt-1-hjemmespil" =>
            "1 (gæt tal) → 50 → 75 → 62 → 2 (RPS) → sten → j → papir → n → 3 (Tic-Tac-Toe) → 5, 1, 9, 3 → 4 (afslut).",
        "projekt-huskeliste" =>
            "2 (vis) → 1 (tilføj) → Øv arrays → 2 → 3 (markér) → 1 → 4 (slet) → 2 → 5 (afslut).",
        "projekt-2-binaer" =>
            "1 → 10111011 → 2 → 75 → 3 → 10111011.01001011.10101010.01010101 → 4 → 187.75.170.85 → 5 (afslut).",
        "projekt-bibliotek" =>
            "2 (vis) → 1 (tilføj) → Design Patterns → GoF → 3 (udlån) → 1 → Mads → 4 (returnér) → 2 → 5 (afslut).",
        "projekt-log-parser" =>
            "1 (txt) → 2 (json) → 3 (csv) → 5 (vis filer) → 4 → app.log.txt → 6 (afslut).",
        _ => null
    };
}
