@using GF2Learn.Web.Client.Components.ProjectDemos

@if (!string.IsNullOrWhiteSpace(ConsoleCode))
{
    <section class="project-solution-section">
        <h2 class="project-solution-heading">Konsol-reference (kør program)</h2>
        <div class="project-solution-console-intro">
            <p class="project-solution-note">
                Her kører I <strong>reference-løsningen</strong> som en færdig konsol-app (<code>.exe</code>) i browseren —
                uden at se C#-koden. Programmet venter ved hvert <code>ReadLine()</code>, præcis som i Visual Studio-terminalen.
            </p>
            <ul class="project-solution-console-steps">
                <li>Tryk <strong>Start program</strong> — terminalen viser output fra <code>Console.WriteLine</code>.</li>
                <li>Når programmet beder om input, skriver du <strong>ét svar ad gangen</strong> i feltet nederst og trykker Enter.</li>
                <li>Fortsæt til programmet er færdigt — prøv menuvalg, gæt, sten/saks/papir osv.</li>
            </ul>
            @if (!string.IsNullOrWhiteSpace(ConsoleScenarioHint))
            {
                <p class="project-solution-scenario"><strong>Forslag til flow:</strong> @ConsoleScenarioHint</p>
            }
            <p class="project-solution-note-muted">
                Første start kan tage et øjeblik (C#-runtime indlæses i browseren). Til aflevering laver I jeres eget konsolprojekt i GitHub.
            </p>
        </div>
        <InteractiveConsoleProgramRunner Code="@ConsoleCode" WindowTitle="@ConsoleWindowTitle" />
    </section>
}

@if (ShowMvp || ShowExtended)
{
    <ProjectSolutionBlazorDemos Slug="@Slug" ShowMvp="ShowMvp" ShowExtended="ShowExtended" />
}

@code {
    [Parameter, EditorRequired] public string Slug { get; set; } = "";
    [Parameter] public string? ConsoleCode { get; set; }
    [Parameter] public bool ShowMvp { get; set; }
    [Parameter] public bool ShowExtended { get; set; }

    private string ConsoleWindowTitle => Slug switch
    {
        "projekt-1-hjemmespil" => "Tidsfordrivsspil.exe",
        "projekt-huskeliste" => "Huskeliste.exe",
        "projekt-jobsoegning" => "Jobsøgning-tracker.exe",
        "projekt-2-binaer" => "BinaerOmformer.exe",
        "projekt-bibliotek" => "Bibliotek.exe",
        "projekt-log-parser" => "LogParser.exe",
        _ => "Konsol-app.exe"
    };

    private string? ConsoleScenarioHint => Slug switch
    {
        "projekt-jobsoegning" =>
            "2 (vis) → 1 (tilføj) → firma/titel/status → 2 → 3 (afslut).",
        "projekt-1-hjemmespil" =>
            "1 (gæt tal) → 50 → 75 → 62 → 2 (RPS) → sten → j → papir → n → 3 (Tic-Tac-Toe) → 5, 1, 9, 3 → 4 (afslut).",
        _ => null
    };
}
