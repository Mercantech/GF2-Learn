@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))
@using GF2Learn.Web.Client.Components.ProjectDemos.Extended
@using GF2Learn.Web.Client.Components.ProjectDemos.Mvp

@if (!string.IsNullOrWhiteSpace(ConsoleCode))
{
    <section class="project-solution-section">
        <h2 class="project-solution-heading">Konsol-reference (kør program)</h2>
        <div class="project-solution-console-intro">
            <p class="project-solution-note">
                Her kører I <strong>reference-løsningen</strong> som en færdig konsol-app (<code>.exe</code>) i browseren —
                samme adfærd som i Visual Studio-terminalen, men <strong>uden at se C#-koden</strong>.
            </p>
            <ul class="project-solution-console-steps">
                <li><strong>Terminalvinduet</strong> nedenfor viser output fra <code>Console.WriteLine</code> / <code>Write</code>.</li>
                <li><strong>Simuleret tastatur</strong> er det, brugeren «taster». Hvert felt = ét <code>ReadLine()</code>; <code>valg</code>, <code>firma</code> osv. er variabelnavnene i jeres kode.</li>
                <li>Ændr værdierne og tryk <strong>Kør igen</strong> for at prøve andre menuvalg.</li>
            </ul>
            @if (!string.IsNullOrWhiteSpace(ConsoleScenarioHint))
            {
                <p class="project-solution-scenario"><strong>Denne demo:</strong> @ConsoleScenarioHint</p>
            }
            <p class="project-solution-note-muted">
                Til aflevering laver I jeres <strong>eget</strong> konsolprojekt i GitHub (menu, validering, README med skærmbillede) — brug demoen som inspiration til flow, ikke som copy-paste.
            </p>
        </div>
        <ConsoleProgramRunner Code="@ConsoleCode" WindowTitle="@ConsoleWindowTitle" />
    </section>
}

@if (ShowMvp)
{
    <section class="project-solution-section">
        <h2 class="project-solution-heading">Blazor — grunddemo (MVP)</h2>
        @RenderMvp()
    </section>
}

@if (ShowExtended)
{
    <section class="project-solution-section">
        <h2 class="project-solution-heading">Blazor — udvidet reference</h2>
        @RenderExtended()
    </section>
}

@code {
    [Parameter, EditorRequired] public string Slug { get; set; } = "";
    [Parameter] public string? ConsoleCode { get; set; }
    [Parameter] public bool ShowMvp { get; set; }
    [Parameter] public bool ShowExtended { get; set; }

    private string ConsoleWindowTitle => Slug switch
    {
        "projekt-1-hjemmespil" => "Tidsfordrivsspil.exe",
        "projekt-huskeliste" => "Huskeliste.exe",
        "projekt-jobsoegning" => "Jobsøgning-tracker.exe",
        "projekt-2-binaer" => "BinaerOmformer.exe",
        "projekt-bibliotek" => "Bibliotek.exe",
        "projekt-log-parser" => "LogParser.exe",
        _ => "Konsol-app.exe"
    };

    private string? ConsoleScenarioHint => Slug switch
    {
        "projekt-jobsoegning" =>
            "Vis listen (menu 2) → tilføj NovaTech-stilling (1 + firma/titel/status) → vis listen igen (2) → afslut (3).",
        "projekt-1-hjemmespil" => "Tre gæt (50, 75, 62) indtil det hemmelige tal rammer.",
        _ => null
    };

    private RenderFragment RenderMvp() => Slug switch
    {
        "projekt-1-hjemmespil" => builder => { builder.OpenComponent<HjemmespilMvpDemo>(0); builder.CloseComponent(); },
        "projekt-huskeliste" => builder => { builder.OpenComponent<HuskelisteMvpDemo>(0); builder.CloseComponent(); },
        "projekt-jobsoegning" => builder => { builder.OpenComponent<JobsoegningMvpDemo>(0); builder.CloseComponent(); },
        "projekt-2-binaer" => builder => { builder.OpenComponent<BinaerMvpDemo>(0); builder.CloseComponent(); },
        "projekt-bibliotek" => builder => { builder.OpenComponent<BibliotekMvpDemo>(0); builder.CloseComponent(); },
        "projekt-log-parser" => builder => { builder.OpenComponent<LogParserMvpDemo>(0); builder.CloseComponent(); },
        _ => builder => { builder.AddContent(0, "Ingen grunddemo for dette projekt."); }
    };

    private RenderFragment RenderExtended() => Slug switch
    {
        "projekt-1-hjemmespil" => builder => { builder.OpenComponent<HjemmespilExtendedDemo>(0); builder.CloseComponent(); },
        "projekt-huskeliste" => builder => { builder.OpenComponent<HuskelisteExtendedDemo>(0); builder.CloseComponent(); },
        "projekt-jobsoegning" => builder => { builder.OpenComponent<JobsoegningExtendedDemo>(0); builder.CloseComponent(); },
        "projekt-2-binaer" => builder => { builder.OpenComponent<BinaerExtendedDemo>(0); builder.CloseComponent(); },
        "projekt-bibliotek" => builder => { builder.OpenComponent<BibliotekExtendedDemo>(0); builder.CloseComponent(); },
        "projekt-log-parser" => builder => { builder.OpenComponent<LogParserExtendedDemo>(0); builder.CloseComponent(); },
        _ => builder => { builder.AddContent(0, "Ingen udvidet demo for dette projekt."); }
    };
}
